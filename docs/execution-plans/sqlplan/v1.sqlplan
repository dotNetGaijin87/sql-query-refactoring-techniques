<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.564" Build="16.0.4255.1"><BatchSequence><Batch><Statements><StmtSimple StatementText="EXEC dbo.MonthlyTaskSummaryReport_v1 &apos;2025-07&apos;" StatementId="1" StatementCompId="1" StatementType="EXECUTE PROC" RetrievedFromCache="false"><StoredProc ProcName="dbo.MonthlyTaskSummaryReport_v1"><Statements><StmtSimple StatementText="&#xd;&#xa;--================================================================================                                                      &#xd;&#xa;--  初期クエリ&#xd;&#xa;--================================================================================&#xd;&#xa;CREATE   PROCEDURE dbo.MonthlyTaskSummaryReport_v1&#xd;&#xa;    @reportMonth VARCHAR(7) &#xd;&#xa;AS&#xd;&#xa;BEGIN&#xd;&#xa;    SET NOCOUNT ON;&#xd;&#xa;&#xd;&#xa;    -- 入力を月の最初の日に変換&#xd;&#xa;    " StatementId="2" StatementCompId="4" StatementType="SET ON/OFF" RetrievedFromCache="true"></StmtSimple><StmtSimple StatementText="DECLARE @reportMonthDate DATE = DATEFROMPARTS(LEFT(@reportMonth, 4), RIGHT(@reportMonth, 2), 1);&#xd;&#xa;&#xd;&#xa;    " StatementId="3" StatementCompId="5" StatementType="ASSIGN" RetrievedFromCache="true"></StmtSimple><StmtSimple StatementText="CREATE TABLE #TaskSummary (&#xd;&#xa;        report_month        VARCHAR(7),&#xd;&#xa;        day_of_month        INT,&#xd;&#xa;        total_tasks         INT,&#xd;&#xa;        completed_tasks     INT,&#xd;&#xa;        delayed_tasks       INT,&#xd;&#xa;        high_priority_tasks INT,&#xd;&#xa;        user_with_most_tasks NVARCHAR(50),&#xd;&#xa;        total_user_tasks    INT&#xd;&#xa;    )" StatementId="4" StatementCompId="6" StatementType="CREATE TABLE" RetrievedFromCache="true"></StmtSimple><StmtSimple StatementText=";&#xd;&#xa;&#xd;&#xa;    DECLARE @day INT = 1;&#xd;&#xa;&#xd;&#xa;    " StatementId="5" StatementCompId="7" StatementType="ASSIGN" RetrievedFromCache="true"></StmtSimple><StmtCond StatementText="WHILE @day &lt;= DAY(EOMONTH(@reportMonthDate))" StatementId="6" StatementCompId="8" StatementType="COND" RetrievedFromCache="true"><Condition></Condition><Then><Statements><StmtSimple StatementText="&#xd;&#xa;    BEGIN&#xd;&#xa;        DECLARE @taskCount INT = 0, &#xd;&#xa;                @completed INT = 0, &#xd;&#xa;                @delayed INT = 0, &#xd;&#xa;                @highPriorityCount INT = 0, &#xd;&#xa;                @topUser NVARCHAR(50), &#xd;&#xa;                @totalUserTasks INT = 0;&#xd;&#xa;&#xd;&#xa;        -- 現在の日付にタスクが存在するか確認&#xd;&#xa;        " StatementId="7" StatementCompId="9" StatementType="ASSIGN" RetrievedFromCache="true"></StmtSimple><StmtCond StatementText="IF EXISTS (&#xd;&#xa;            SELECT 1 FROM task &#xd;&#xa;            WHERE due_date &gt;= DATEADD(DAY, @day - 1, @reportMonthDate) &#xd;&#xa;              AND due_date &lt; DATEADD(DAY, @day, @reportMonthDate)&#xd;&#xa;        )" StatementId="8" StatementCompId="10" StatementType="COND WITH QUERY" StatementSqlHandle="0x0900C978F6C4F1EF311F7B2A44BB34F850260000000000000000000000000000000000000000000000000000" DatabaseContextSettingsId="2" ParentObjectId="1573580644" StatementParameterizationType="0" RetrievedFromCache="true" StatementSubTreeCost="0.00328854" StatementEstRows="1" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0x421566D768CE7513" QueryPlanHash="0x080AE7029934FE62" StatementOptmEarlyAbortReason="GoodEnoughPlanFound" CardinalityEstimationModelVersion="160"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><Condition><QueryPlan CachedPlanSize="24" CompileTime="0" CompileCPU="0" CompileMemory="456"><MemoryGrantInfo SerialRequiredMemory="0" SerialDesiredMemory="0" GrantedMemory="0" MaxUsedMemory="0"></MemoryGrantInfo><OptimizerHardwareDependentProperties EstimatedAvailableMemoryGrant="81388" EstimatedPagesCached="81388" EstimatedAvailableDegreeOfParallelism="8" MaxCompileMemory="8463904"></OptimizerHardwareDependentProperties><RelOp NodeId="0" PhysicalOp="Compute Scalar" LogicalOp="Compute Scalar" EstimateRows="1" EstimateIO="0" EstimateCPU="1e-07" AvgRowSize="11" EstimatedTotalSubtreeCost="0.00328854" Parallel="0" EstimateRebinds="0" EstimateRewinds="0" EstimatedExecutionMode="Row"><OutputList><ColumnReference Column="Expr1003"></ColumnReference></OutputList><ComputeScalar><DefinedValues><DefinedValue><ColumnReference Column="Expr1003"></ColumnReference><ScalarOperator ScalarString="CASE WHEN [Expr1004] THEN (1) ELSE (0) END"><IF><Condition><ScalarOperator><Identifier><ColumnReference Column="Expr1004"></ColumnReference></Identifier></ScalarOperator></Condition><Then><ScalarOperator><Const ConstValue="(1)"></Const></ScalarOperator></Then><Else><ScalarOperator><Const ConstValue="(0)"></Const></ScalarOperator></Else></IF></ScalarOperator></DefinedValue></DefinedValues><RelOp NodeId="1" PhysicalOp="Nested Loops" LogicalOp="Left Semi Join" EstimateRows="1" EstimateIO="0" EstimateCPU="4.18e-06" AvgRowSize="9" EstimatedTotalSubtreeCost="0.00328844" Parallel="0" EstimateRebinds="0" EstimateRewinds="0" EstimatedExecutionMode="Row"><OutputList><ColumnReference Column="Expr1004"></ColumnReference></OutputList><NestedLoops Optimized="0"><DefinedValues><DefinedValue><ColumnReference Column="Expr1004"></ColumnReference></DefinedValue></DefinedValues><ProbeColumn><ColumnReference Column="Expr1004"></ColumnReference></ProbeColumn><RelOp NodeId="2" PhysicalOp="Constant Scan" LogicalOp="Constant Scan" EstimateRows="1" EstimateIO="0" EstimateCPU="1.157e-06" AvgRowSize="9" EstimatedTotalSubtreeCost="1.157e-06" Parallel="0" EstimateRebinds="0" EstimateRewinds="0" EstimatedExecutionMode="Row"><OutputList></OutputList><ConstantScan></ConstantScan></RelOp><RelOp NodeId="3" PhysicalOp="Index Seek" LogicalOp="Index Seek" EstimateRows="1" EstimateRowsWithoutRowGoal="8215.84" EstimatedRowsRead="8215.84" EstimateIO="0.0127546" EstimateCPU="0.00919442" AvgRowSize="9" EstimatedTotalSubtreeCost="0.0032831" TableCardinality="50000" Parallel="0" EstimateRebinds="0" EstimateRewinds="0" EstimatedExecutionMode="Row"><OutputList></OutputList><IndexScan Ordered="1" ScanDirection="FORWARD" ForcedIndex="0" ForceSeek="0" ForceScan="0" NoExpandHint="0" Storage="RowStore"><DefinedValues></DefinedValues><Object Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]" Index="[idx_task_due_date]" IndexKind="NonClustered" Storage="RowStore"></Object><SeekPredicates><SeekPredicateNew><SeekKeys><StartRange ScanType="GE"><RangeColumns><ColumnReference Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]" Column="due_date"></ColumnReference></RangeColumns><RangeExpressions><ScalarOperator ScalarString="dateadd(day,[@day]-(1),[@reportMonthDate])"><Intrinsic FunctionName="dateadd"><ScalarOperator><Const ConstValue="(4)"></Const></ScalarOperator><ScalarOperator><Arithmetic Operation="SUB"><ScalarOperator><Identifier><ColumnReference Column="@day"></ColumnReference></Identifier></ScalarOperator><ScalarOperator><Const ConstValue="(1)"></Const></ScalarOperator></Arithmetic></ScalarOperator><ScalarOperator><Identifier><ColumnReference Column="@reportMonthDate"></ColumnReference></Identifier></ScalarOperator></Intrinsic></ScalarOperator></RangeExpressions></StartRange><EndRange ScanType="LT"><RangeColumns><ColumnReference Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]" Column="due_date"></ColumnReference></RangeColumns><RangeExpressions><ScalarOperator ScalarString="dateadd(day,[@day],[@reportMonthDate])"><Intrinsic FunctionName="dateadd"><ScalarOperator><Const ConstValue="(4)"></Const></ScalarOperator><ScalarOperator><Identifier><ColumnReference Column="@day"></ColumnReference></Identifier></ScalarOperator><ScalarOperator><Identifier><ColumnReference Column="@reportMonthDate"></ColumnReference></Identifier></ScalarOperator></Intrinsic></ScalarOperator></RangeExpressions></EndRange></SeekKeys></SeekPredicateNew></SeekPredicates></IndexScan></RelOp></NestedLoops></RelOp></ComputeScalar></RelOp></QueryPlan></Condition><Then><Statements><StmtSimple StatementText="&#xd;&#xa;        BEGIN&#xd;&#xa;            -- 現在の日付におけるタスク数とトップユーザーの取得&#xd;&#xa;            SELECT&#xd;&#xa;                @taskCount = COUNT(*),&#xd;&#xa;                @completed = SUM(CASE WHEN ts.status_name = &apos;Completed&apos; THEN 1 ELSE 0 END),&#xd;&#xa;                @delayed = SUM(CASE WHEN ts.status_name = &apos;Delayed&apos; THEN 1 ELSE 0 END),&#xd;&#xa;                @highPriorityCount = SUM(CASE WHEN tp.priority_name = &apos;High&apos; THEN 1 ELSE 0 END)&#xd;&#xa;            FROM task t&#xd;&#xa;            LEFT JOIN task_status ts ON t.status_id = ts.status_id&#xd;&#xa;            LEFT JOIN task_priority tp ON t.priority_id = tp.priority_id&#xd;&#xa;            WHERE t.due_date &gt;= DATEADD(DAY, @day - 1, @reportMonthDate) &#xd;&#xa;              AND t.due_date &lt; DATEADD(DAY, @day, @reportMonthDate)" StatementId="9" StatementCompId="11" StatementType="SELECT" RetrievedFromCache="false" StatementSubTreeCost="0.493854" StatementEstRows="1" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0x73101812BC3FD26D" QueryPlanHash="0x87826FDEDC83639D" StatementOptmEarlyAbortReason="TimeOut" CardinalityEstimationModelVersion="160"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan CachedPlanSize="96" CompileTime="3" CompileCPU="3" CompileMemory="696"><MissingIndexes><MissingIndexGroup Impact="65.0757"><MissingIndex Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]"><ColumnGroup Usage="INEQUALITY"><Column Name="[due_date]" ColumnId="5"></Column></ColumnGroup><ColumnGroup Usage="INCLUDE"><Column Name="[status_id]" ColumnId="6"></Column><Column Name="[priority_id]" ColumnId="7"></Column