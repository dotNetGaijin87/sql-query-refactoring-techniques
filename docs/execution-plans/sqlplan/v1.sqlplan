topUser = u.first_name + &apos; &apos; + u.last_name, &#xd;&#xa;                        @totalUserTasks = COUNT(t.task_id) &#xd;&#xa;            FROM task t&#xd;&#xa;            JOIN [user] u ON t.assigned_to_user_id = u.user_id&#xd;&#xa;            WHERE t.due_date &gt;= DATEADD(DAY, @day - 1, @reportMonthDate) &#xd;&#xa;              AND t.due_date &lt; DATEADD(DAY, @day, @reportMonthDate)&#xd;&#xa;            GROUP BY u.first_name, u.last_name&#xd;&#xa;            ORDER BY COUNT(t.task_id) DESC" StatementId="10" StatementCompId="12" StatementType="SELECT" RetrievedFromCache="false" StatementSubTreeCost="0.475765" StatementEstRows="1" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0xFEF476C7B3F450C4" QueryPlanHash="0x5285D9EF62B80F26" StatementOptmEarlyAbortReason="GoodEnoughPlanFound" CardinalityEstimationModelVersion="160"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan CachedPlanSize="56" CompileTime="3" CompileCPU="3" CompileMemory="632"><MissingIndexes><MissingIndexGroup Impact="68.9512"><MissingIndex Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]"><ColumnGroup Usage="INEQUALITY"><Column Name="[due_date]" ColumnId="5"></Column></ColumnGroup><ColumnGroup Usage="INCLUDE"><Column Name="[assigned_to_user_id]" ColumnId="3"></Column></ColumnGroup></MissingIndex></MissingIndexGroup></MissingIndexes><MemoryGrantInfo SerialRequiredMemory="1536" SerialDesiredMemory="1584" GrantedMemory="0" MaxUsedMemory="0"></MemoryGrantInfo><OptimizerHardwareDependentProperties EstimatedAvailableMemoryGrant="81388" EstimatedPagesCached="81388" EstimatedAvailableDegreeOfParallelism="8" MaxCompileMemory="8442120"></OptimizerHardwareDependentProperties><OptimizerStatsUsage><StatisticsInfo LastUpdate="2026-06-24T07:47:43.35" ModificationCount="8" SamplingPercent="100" Statistics="[idx_task_assig