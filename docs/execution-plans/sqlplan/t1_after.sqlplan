<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.564" Build="16.0.4255.1"><BatchSequence><Batch><Statements><StmtSimple StatementText="SELECT u.user_id,u.first_name,u.last_name,t.task_id,t.task_name,t.due_date,tp.priority_name&#xd;&#xa;FROM [user] u&#xd;&#xa;JOIN (SELECT t.assigned_to_user_id,t.task_id,t.task_name,t.due_date,t.priority_id,&#xd;&#xa;        ROW_NUMBER() OVER (PARTITION BY t.assigned_to_user_id ORDER BY t.due_date ASC,t.priority_id DESC,t.task_id ASC) AS rn&#xd;&#xa;      FROM task t WHERE t.assigned_to_user_id IS NOT NULL) t ON u.user_id=t.assigned_to_user_id&#xd;&#xa;JOIN task_priority tp ON t.priority_id=tp.priority_id&#xd;&#xa;WHERE t.rn=1&#xd;&#xa;ORDER BY u.user_id" StatementId="1" StatementCompId="1" StatementType="SELECT" RetrievedFromCache="false" StatementSubTreeCost="2.03166" StatementEstRows="50000" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0x3432423B9D3B30B9" QueryPlanHash="0xCA48982F23CBD84B" CardinalityEstimationModelVersion="160"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan CachedPlanSize="96" CompileTime="5" CompileCPU="5" CompileMemory="600"><ThreadStat Branches="4"></ThreadStat><MemoryGrantInfo SerialRequiredMemory="1664" SerialDesiredMemory="27896" GrantedMemory="0" MaxUsedMemory="0"></MemoryGrantInfo><OptimizerHardwareDependentProperties EstimatedAvailableMemoryGrant="81388" EstimatedPagesCached="81388" EstimatedAvailableDegreeOfParallelism="8" MaxCompileMemory="8442192"></OptimizerHardwareDependentProperties><OptimizerStatsUsage><StatisticsInfo LastUpdate="2026-06-24T07:52:34.85" ModificationCount="0" SamplingPercent="100" Statistics="[_WA_Sys_00000007_47DBAE45]" Table="[task]" Schema="[dbo]" Database="[SqlRefactoring]"></StatisticsInfo><StatisticsInfo LastUpdate="2026-06-24T07:47:43.35" Modification