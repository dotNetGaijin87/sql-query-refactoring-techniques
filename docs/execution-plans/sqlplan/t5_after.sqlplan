<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.564" Build="16.0.4255.1"><BatchSequence><Batch><Statements><StmtSimple StatementText="SELECT tc.user_id,u.first_name,u.last_name,ts.total_tasks,ts.avg_completion_days,COUNT(tc.comment_id) AS total_comments&#xd;&#xa;FROM [user] u&#xd;&#xa;JOIN task_comment tc ON tc.user_id=u.user_id&#xd;&#xa;JOIN (SELECT TOP 5 t.assigned_to_user_id,COUNT(t.task_id) AS total_tasks,AVG(CAST(DATEDIFF(DAY,t.due_date,&apos;2025-08-12&apos;) AS FLOAT)) AS avg_completion_days&#xd;&#xa;      FROM task t JOIN task_status ts ON t.status_id=ts.status_id JOIN task_priority tp ON t.priority_id=tp.priority_id&#xd;&#xa;      WHERE ts.status_name=&apos;Completed&apos; AND tp.priority_name IN (&apos;High&apos;,&apos;Critical&apos;)&#xd;&#xa;      GROUP BY t.assigned_to_user_id ORDER BY total_tasks DESC) ts ON u.user_id=ts.assigned_to_user_id&#xd;&#xa;GROUP BY tc.user_id,u.first_name,u.last_name,ts.total_tasks,ts.avg_completion_days&#xd;&#xa;ORDER BY ts.total_tasks DESC,tc.user_id" StatementId="1" StatementCompId="1" StatementType="SELECT" RetrievedFromCache="false" StatementSubTreeCost="0.500299" StatementEstRows="5" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0x3B596CD60C69D33F" QueryPlanHash="0x8BC5391DF468D9A2" StatementOptmEarlyAbortReason="TimeOut" CardinalityEstimationModelVersion="160" BatchModeOnRowStoreUsed="true"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan CachedPlanSize="144" CompileTime="6" CompileCPU="6" CompileMemory="1192"><MissingIndexes><MissingIndexGroup Impact="62.026"><MissingIndex Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]"><ColumnGroup Usage="EQUALITY"><Column Name="[status_id]" ColumnId="6"></Column></ColumnGroup><ColumnGroup Usage="INCLUDE"><Column Name="[assigned_to_user_id]" ColumnId=