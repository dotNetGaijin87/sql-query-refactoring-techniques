<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.564" Build="16.0.4255.1"><BatchSequence><Batch><Statements><StmtSimple StatementText="SELECT TOP 5 u.user_id,u.first_name,u.last_name,&#xd;&#xa;    COALESCE(COUNT(DISTINCT t.task_id),0) AS total_tasks,&#xd;&#xa;    COALESCE(AVG(CAST(DATEDIFF(DAY,t.due_date,&apos;2025-08-12&apos;) AS FLOAT)),0) AS avg_completion_days,&#xd;&#xa;    COUNT(DISTINCT tc.comment_id) AS total_comments&#xd;&#xa;FROM [user] u&#xd;&#xa;JOIN task_comment tc ON u.user_id=tc.user_id&#xd;&#xa;JOIN task t ON u.user_id=t.assigned_to_user_id&#xd;&#xa;JOIN task_status ts ON t.status_id=ts.status_id&#xd;&#xa;JOIN task_priority tp ON t.priority_id=tp.priority_id&#xd;&#xa;WHERE ts.status_name=&apos;Completed&apos; AND tp.priority_name IN (&apos;High&apos;,&apos;Critical&apos;)&#xd;&#xa;GROUP BY u.user_id,u.first_name,u.last_name&#xd;&#xa;ORDER BY COUNT(DISTINCT t.task_id) DESC,u.user_id ASC" StatementId="1" StatementCompId="1" StatementType="SELECT" RetrievedFromCache="false" StatementSubTreeCost="2.0728" StatementEstRows="5" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0x03DBF6C1B748D7C2" QueryPlanHash="0x6FB64904438C7FB7" StatementOptmEarlyAbortReason="TimeOut" CardinalityEstimationModelVersion="160" BatchModeOnRowStoreUsed="true"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan CachedPlanSize="224" CompileTime="88" CompileCPU="88" CompileMemory="7288"><ThreadStat Branches="1"></ThreadStat><MissingIndexes><MissingIndexGroup Impact="11.0194"><MissingIndex Database="[SqlRefactoring]" Schema="[dbo]" Table="[task]"><ColumnGroup Usage="EQUALITY"><Column Name="[priority_id]" ColumnId="7"></Column></ColumnGroup><ColumnGroup Usage="INCLUDE"><Column Name="[assigned_to_user_id]" ColumnId="3"></Column><Column Name="[due_date]" ColumnId="5"></